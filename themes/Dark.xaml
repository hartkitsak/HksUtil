<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="windowBackground"      Color="#1C1C1E"/>
    <SolidColorBrush x:Key="headerBackground"      Color="#242426"/>
    <SolidColorBrush x:Key="headerBorder"          Color="#3A3A3C"/>
    <SolidColorBrush x:Key="footerBackground"      Color="#242426"/>
    <SolidColorBrush x:Key="footerBorder"          Color="#3A3A3C"/>

    <!-- Cards -->
    <SolidColorBrush x:Key="cardBackground"        Color="#2C2C2E"/>
    <SolidColorBrush x:Key="cardForeground"        Color="#D4CEBC"/>
    <SolidColorBrush x:Key="cardBorder"            Color="#48484A"/>

    <!-- Accent (Soft Blue) -->
    <SolidColorBrush x:Key="accentColor"           Color="#4D9DE0"/>
    <SolidColorBrush x:Key="accentHover"           Color="#3A87C8"/>

    <!-- Text -->
    <SolidColorBrush x:Key="pageTitleColor"        Color="#E8E0CC"/>
    <SolidColorBrush x:Key="categoryHeaderColor"   Color="#4D9DE0"/>
    <SolidColorBrush x:Key="textMuted"             Color="#8E8E93"/>

    <!-- TextBox -->
    <SolidColorBrush x:Key="textBoxBackground"     Color="#2C2C2E"/>
    <SolidColorBrush x:Key="textBoxForeground"     Color="#D4CEBC"/>
    <SolidColorBrush x:Key="textBoxBorder"         Color="#48484A"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="dangerColor"           Color="#C0392B"/>
    <SolidColorBrush x:Key="dangerHover"           Color="#962D22"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="selectedBorder"        Color="#4D9DE0"/>
    <SolidColorBrush x:Key="selectedBackground"    Color="#162840"/>

    <!-- Hover / Secondary -->
    <SolidColorBrush x:Key="hoverBackground"       Color="#262628"/>
    <SolidColorBrush x:Key="secondaryBackground"   Color="#242426"/>
    <SolidColorBrush x:Key="secondaryHover"        Color="#262628"/>
</ResourceDictionary>