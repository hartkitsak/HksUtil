<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="windowBackground"      Color="#0F0D1A"/>
    <SolidColorBrush x:Key="headerBackground"      Color="#13101F"/>
    <SolidColorBrush x:Key="headerBorder"          Color="#2A2040"/>
    <SolidColorBrush x:Key="footerBackground"      Color="#13101F"/>
    <SolidColorBrush x:Key="footerBorder"          Color="#2A2040"/>

    <!-- Cards -->
    <SolidColorBrush x:Key="cardBackground"        Color="#1C1730"/>
    <SolidColorBrush x:Key="cardForeground"        Color="#C8BEE8"/>
    <SolidColorBrush x:Key="cardBorder"            Color="#2E2450"/>

    <!-- Accent (Violet) -->
    <SolidColorBrush x:Key="accentColor"           Color="#7C3AED"/>
    <SolidColorBrush x:Key="accentHover"           Color="#6D28D9"/>

    <!-- Text -->
    <SolidColorBrush x:Key="pageTitleColor"        Color="#F0EBFF"/>
    <SolidColorBrush x:Key="categoryHeaderColor"   Color="#A78BFA"/>
    <SolidColorBrush x:Key="textMuted"             Color="#6B5F8A"/>

    <!-- TextBox -->
    <SolidColorBrush x:Key="textBoxBackground"     Color="#1C1730"/>
    <SolidColorBrush x:Key="textBoxForeground"     Color="#C8BEE8"/>
    <SolidColorBrush x:Key="textBoxBorder"         Color="#3D3060"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="dangerColor"           Color="#C026D3"/>
    <SolidColorBrush x:Key="dangerHover"           Color="#A21CAF"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="selectedBorder"        Color="#A78BFA"/>
    <SolidColorBrush x:Key="selectedBackground"    Color="#1E1540"/>

    <!-- Hover / Secondary -->
    <SolidColorBrush x:Key="hoverBackground"       Color="#241D3D"/>
    <SolidColorBrush x:Key="secondaryBackground"   Color="#201A38"/>
    <SolidColorBrush x:Key="secondaryHover"        Color="#2E2455"/>
</ResourceDictionary>