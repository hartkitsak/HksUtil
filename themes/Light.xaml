<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="windowBackground"      Color="#F8F4F0"/>
    <SolidColorBrush x:Key="headerBackground"      Color="#F0EBE6"/>
    <SolidColorBrush x:Key="headerBorder"          Color="#D4C5B8"/>
    <SolidColorBrush x:Key="footerBackground"      Color="#F0EBE6"/>
    <SolidColorBrush x:Key="footerBorder"          Color="#D4C5B8"/>

    <!-- Cards -->
    <SolidColorBrush x:Key="cardBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="cardForeground"        Color="#3D2E24"/>
    <SolidColorBrush x:Key="cardBorder"            Color="#D4C5B8"/>

    <!-- Accent (Rose Gold) -->
    <SolidColorBrush x:Key="accentColor"           Color="#C9727A"/>
    <SolidColorBrush x:Key="accentHover"           Color="#B05860"/>

    <!-- Text -->
    <SolidColorBrush x:Key="pageTitleColor"        Color="#1A0F0A"/>
    <SolidColorBrush x:Key="categoryHeaderColor"   Color="#C9727A"/>
    <SolidColorBrush x:Key="textMuted"             Color="#8A7568"/>

    <!-- TextBox -->
    <SolidColorBrush x:Key="textBoxBackground"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="textBoxForeground"     Color="#3D2E24"/>
    <SolidColorBrush x:Key="textBoxBorder"         Color="#D4C5B8"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="dangerColor"           Color="#D44A5A"/>
    <SolidColorBrush x:Key="dangerHover"           Color="#B83848"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="selectedBorder"        Color="#C9727A"/>
    <SolidColorBrush x:Key="selectedBackground"    Color="#FCE8EC"/>

    <!-- Hover / Secondary -->
    <SolidColorBrush x:Key="hoverBackground"       Color="#F5EEEA"/>
    <SolidColorBrush x:Key="secondaryBackground"   Color="#F0EBE6"/>
    <SolidColorBrush x:Key="secondaryHover"        Color="#E8DED6"/>
</ResourceDictionary>