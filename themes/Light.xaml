<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Backgrounds -->
    <SolidColorBrush x:Key="windowBackground"      Color="#F4F8FC"/>
    <SolidColorBrush x:Key="headerBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="headerBorder"          Color="#C4D9ED"/>
    <SolidColorBrush x:Key="footerBackground"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="footerBorder"          Color="#C4D9ED"/>

    <!-- Cards -->
    <SolidColorBrush x:Key="cardBackground"        Color="#FFFFFF"/>
    <SolidColorBrush x:Key="cardForeground"        Color="#1A2733"/>
    <SolidColorBrush x:Key="cardBorder"            Color="#BDD3E8"/>

    <!-- Accent (Soft Blue) -->
    <SolidColorBrush x:Key="accentColor"           Color="#4D9DE0"/>
    <SolidColorBrush x:Key="accentHover"           Color="#3A87C8"/>

    <!-- Text -->
    <SolidColorBrush x:Key="pageTitleColor"        Color="#1A2733"/>
    <SolidColorBrush x:Key="categoryHeaderColor"   Color="#4D9DE0"/>
    <SolidColorBrush x:Key="textMuted"             Color="#7A96AE"/>

    <!-- TextBox -->
    <SolidColorBrush x:Key="textBoxBackground"     Color="#FFFFFF"/>
    <SolidColorBrush x:Key="textBoxForeground"     Color="#1A2733"/>
    <SolidColorBrush x:Key="textBoxBorder"         Color="#BDD3E8"/>

    <!-- Danger -->
    <SolidColorBrush x:Key="dangerColor"           Color="#C0392B"/>
    <SolidColorBrush x:Key="dangerHover"           Color="#962D22"/>

    <!-- Selection -->
    <SolidColorBrush x:Key="selectedBorder"        Color="#4D9DE0"/>
    <SolidColorBrush x:Key="selectedBackground"    Color="#E0EEFA"/>

    <!-- Hover / Secondary -->
    <SolidColorBrush x:Key="hoverBackground"       Color="#EBF3FA"/>
    <SolidColorBrush x:Key="secondaryBackground"   Color="#FFFFFF"/>
    <SolidColorBrush x:Key="secondaryHover"        Color="#EBF3FA"/>
</ResourceDictionary>