<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HksUtil v2.0 - Windows Optimizer" Width="1200" Height="750" MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen" Background="#1A1A1A"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style x:Key="CategoryHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#3B82F6"/>
            <Setter Property="Margin" Value="10,15,10,5"/>
        </Style>
        <Style x:Key="AppCardCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="Wrap" MaxWidth="500"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#22C55E"/>
                                <Setter TargetName="RootBorder" Property="Background" Value="#1A3A1A"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TweakCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center" HorizontalAlignment="Left" TextWrapping="Wrap" MaxWidth="500"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#22C55E"/>
                                <Setter TargetName="RootBorder" Property="Background" Value="#1A3A1A"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="RootBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#22C55E"/>
                                <Setter TargetName="RootBorder" Property="Background" Value="#1A3A1A"/>
                                <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#333333"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PresetCard" TargetType="Button">
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="180"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FeatureCard" TargetType="Button">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="MinWidth" Value="280"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333333"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="2,2,2,2"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Background" Value="#DC2626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#B91C1C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#333333"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#444444"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
<Border x:Name="SidebarBorder" Grid.Column="0" Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="0,0,1,0">
             <Grid Margin="10">
                 <StackPanel VerticalAlignment="Top">
                     <TextBlock x:Name="TitleText" Text="HksUtil" FontSize="22" FontWeight="Bold" Foreground="#3B82F6" Margin="10,15,10,5"/>
                     <TextBlock x:Name="SubtitleText" Text="v2.0 Optimizer" FontSize="11" Foreground="#888888" Margin="10,0,10,20"/>
                     <Button x:Name="NavInstall" Content="Install Apps" Style="{StaticResource NavButton}"/>
                     <Button x:Name="NavTweaks" Content="Tweaks" Style="{StaticResource NavButton}"/>
                     <Button x:Name="NavFeatures" Content="Features" Style="{StaticResource NavButton}"/>
                     <Button x:Name="NavPreferences" Content="Preferences" Style="{StaticResource NavButton}"/>
                 </StackPanel>
                 <StackPanel VerticalAlignment="Bottom">
                     <Button x:Name="NavClean" Content="Clean" Style="{StaticResource NavButton}"/>
                     <Button x:Name="NavLegacy" Content="Legacy Panels" Style="{StaticResource NavButton}"/>
                     <Button x:Name="NavSettings" Content="Settings" Style="{StaticResource NavButton}"/>
                 </StackPanel>
             </Grid>
         </Border>
        <Grid Grid.Column="1">
            <ScrollViewer x:Name="PageInstall" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleInstall" Text="Install Applications" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                    <TextBlock x:Name="DescInstall" Text="Search and manage application installations via WinGet or Chocolatey." Foreground="#888888" FontSize="12" Margin="0,0,0,10"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Grid Width="260">
                            <TextBox x:Name="SearchBox" Padding="8,5" Background="#2A2A2A" Foreground="#CCCCCC" BorderBrush="#444444" BorderThickness="1"/>
                            <TextBlock x:Name="SearchHint" Text="Search apps..." Foreground="#888888" Margin="8,5,0,0" IsHitTestVisible="False" Visibility="Visible"/>
                        </Grid>
                        <Button x:Name="BtnClearSearch" Content="X" Width="28" Height="28" Margin="5,0,0,0" Background="#3A3A3A" Foreground="#888888" BorderBrush="#444444" BorderThickness="1" FontSize="12" Cursor="Hand" FontWeight="Bold"/>
                        <CheckBox x:Name="ChkShowInstalled" Content="Installed" Foreground="#CCCCCC" Margin="10,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="LabelPkgMgr" Text="Package Manager" FontWeight="SemiBold" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="12,0,8,0"/>
                        <RadioButton x:Name="PkgWinGet" Content="WinGet" Foreground="#3B82F6" FontWeight="Bold" IsChecked="True" GroupName="PkgMgr" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <RadioButton x:Name="PkgChoco" Content="Choco" Foreground="#CCCCCC" FontWeight="SemiBold" GroupName="PkgMgr" Margin="0,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="PkgSelectionBorder" Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="6" Padding="10,8" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Button x:Name="BtnInstall" Content="Install / Upgrade" Style="{StaticResource ActionBtn}" Width="120"/>
                                <Button x:Name="BtnUninstall" Content="Uninstall" Style="{StaticResource DangerBtn}" Width="90"/>
                                <Button x:Name="BtnSelectAll" Content="Select All" Style="{StaticResource SecondaryBtn}" Width="90"/>
                                <Button x:Name="BtnClearSelection" Content="Clear" Style="{StaticResource SecondaryBtn}" Width="70"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <Button x:Name="BtnCollapseAll" Content="Collapse" Style="{StaticResource SecondaryBtn}" Width="80"/>
                                <Button x:Name="BtnExpandAll" Content="Expand" Style="{StaticResource SecondaryBtn}" Width="80"/>
                                <TextBlock x:Name="LblSelectedCount" Text="0" Foreground="#888888" VerticalAlignment="Center" Margin="8,0,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Grid Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="AppPanel1" Grid.Column="0" Margin="0,0,6,0"/>
                        <StackPanel x:Name="AppPanel2" Grid.Column="1" Margin="3,0"/>
                        <StackPanel x:Name="AppPanel3" Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer x:Name="PageTweaks" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleTweaks" Text="System Tweaks" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescTweaks" Text="Select tweaks to apply. You can undo them later." Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="TweaksPanel1" Grid.Column="0" Margin="0,0,6,0"/>
                        <StackPanel x:Name="TweaksPanel2" Grid.Column="1" Margin="3,0"/>
                        <StackPanel x:Name="TweaksPanel3" Grid.Column="2" Margin="6,0,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button x:Name="BtnRunTweaks" Content="Apply Selected Tweaks" Style="{StaticResource ActionBtn}"/>
                        <Button x:Name="BtnUndoTweaks" Content="Undo All Tweaks" Style="{StaticResource DangerBtn}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PageFeatures" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleFeatures" Text="Features &amp; Fixes" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescFeatures" Text="Enable Windows features and run system fixes." Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    <TextBlock x:Name="FeaturesSectionHeader" Text="Windows Features" FontSize="16" FontWeight="SemiBold" Foreground="#3B82F6" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel x:Name="FeaturesPanel1" Grid.Column="0" Margin="0,0,10,0"/>
                        <StackPanel x:Name="FeaturesPanel2" Grid.Column="1" Margin="10,0,0,0"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button x:Name="BtnRunFeatures" Content="Run Features" Style="{StaticResource ActionBtn}"/>
                    </StackPanel>
                    <TextBlock x:Name="FixesSectionHeader" Text="Fixes" FontSize="16" FontWeight="SemiBold" Foreground="#3B82F6" Margin="0,25,0,10"/>
                    <WrapPanel x:Name="FixesWrapPanel"/>
                </StackPanel>
            </ScrollViewer>

            <ScrollViewer x:Name="PagePreferences" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitlePreferences" Text="Preferences" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescPreferences" Text="Toggle Windows settings and behavior preferences." Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    <Border x:Name="PrefsBorder" Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="6" Padding="15">
                        <WrapPanel x:Name="PrefsWrapPanel"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer x:Name="PageClean" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleClean" Text="System Cleanup" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescClean" Text="Clean temporary files and system cache." Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnCleanTemp" Content="Clean Temp Files" Style="{StaticResource ActionBtn}" Width="200" HorizontalAlignment="Left"/>
                        <Button x:Name="BtnCleanUpdate" Content="Clean Update Cache" Style="{StaticResource SecondaryBtn}" Width="200" HorizontalAlignment="Left"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer x:Name="PageLegacy" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleLegacy" Text="Legacy Windows Panels" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescLegacy" Text="Quick access to classic Windows control panels and system tools." Foreground="#888888" FontSize="12" Margin="0,0,0,20"/>
                    <WrapPanel x:Name="LegacyWrapPanel"/>
                </StackPanel>
            </ScrollViewer>
            <ScrollViewer x:Name="PageSettings" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <TextBlock x:Name="TitleSettings" Text="Settings" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescSettings" Text="Customize appearance and preferences." Foreground="#888888" FontSize="12" Margin="0,0,0,15"/>
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock x:Name="LabelTheme" Text="Theme" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="ThemeSelector" Width="200" Padding="8,5" Background="#2A2A2A" Foreground="#CCCCCC" BorderBrush="#444444" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="CurrentThemeLabel" Text="Dark" Foreground="#888888" FontSize="11" Margin="0,5,0,0"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock x:Name="LabelDns" Text="DNS Provider" Foreground="#CCCCCC" FontSize="13" Margin="0,0,0,5"/>
                        <ComboBox x:Name="DnsSelector" Width="300" Padding="8,5" Background="#2A2A2A" Foreground="#CCCCCC" BorderBrush="#444444" HorizontalAlignment="Left"/>
                        <Button x:Name="BtnApplyDns" Content="Apply DNS" Style="{StaticResource ActionBtn}" Width="150" HorizontalAlignment="Left" Margin="0,10,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                        <Button x:Name="BtnExportConfig" Content="Export Config" Style="{StaticResource SecondaryBtn}"/>
                        <Button x:Name="BtnImportConfig" Content="Import Config" Style="{StaticResource SecondaryBtn}"/>
                        <Button x:Name="BtnResetSettings" Content="Reset to Default" Style="{StaticResource DangerBtn}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
            <Border x:Name="StatusBar" Background="#1A1A1A" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" VerticalAlignment="Bottom" Height="26">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#888888" FontSize="11" Padding="8,4"/>
            </Border>
        </Grid>
    </Grid>
</Window>